# DataFoundry runtime CopilotKit / AG-UI endpoint.
NEXT_PUBLIC_AGENT_RUNTIME_URL=http://127.0.0.1:8787/api/copilotkit

# Must match root .env DATAFOUNDRY_AUTH_MODE. Frontend reads this at build/dev start.
#   dev      — skip /login, use built-in dev-user (default for local work).
#   password — show login/register; must match backend password mode.
NEXT_PUBLIC_DATAFOUNDRY_AUTH_MODE=dev
